# Configuração de Ambiente
NODE_ENV=development
PORT=3333

# DB CONFIGS (Utilize credenciais de menor privilégio em Produção!)
DIALECT=postgres
HOST=localhost
DB_USERNAME=tripnow_app
PASSWORD=sua_senha_segura_do_banco
DATABASE=trip_now
DB_PORT=5432

# REDIS CONFIGS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=senha_opcional_segura
# Opcionalmente:
# REDIS_USERNAME=seu_usuario

# E-MAIL CONFIGS (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=seu_email@gmail.com
MAIL_PASS=senha_de_app_gerada

# SECURITY SECRETS (NUNCA COLOQUE SENHAS REAIS AQUI!)
# Gerar chaves fortes usando no terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

HASH_BCRYPT=sua_hash_salt_aqui
SECRET_CRYPTO=chave_de_criptografia_de_16_caracteres_min

# Tokens de Autenticação
JWT_SECRET=sua_chave_jwt_super_longa_aqui
EXPIRE_IN=15m
REFRESH_JWT_SECRET=sua_chave_refresh_jwt_ainda_mais_longa_aqui
REFRESH_EXPIRE_IN=7d

# APIS DE TERCEIROS (Suas chaves de desenvolvimento)
GEOAPIFY_API_KEY=
PEXELS_API_KEY=
TRIPADVISOR_API_KEY=
PIXABAY_API_KEY=
